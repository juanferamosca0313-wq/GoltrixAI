        "borderWidth": 1,
        "borderColor": "#3F3F46"
      },
      "secondary_text": {
        "color": "#FAFAFA",
        "fontWeight": "600",
        "fontSize": 16
      }
    },
    "Card": {
      "backgroundColor": "#18181B",
      "borderRadius": 16,
      "borderWidth": 1,
      "borderColor": "#27272A",
      "padding": 20
    },
    "Input": {
      "backgroundColor": "#27272A",
      "borderRadius": 12,
      "height": 50,
      "color": "#FAFAFA",
      "paddingHorizontal": 16,
      "borderWidth": 1,
      "borderColor": "transparent"
