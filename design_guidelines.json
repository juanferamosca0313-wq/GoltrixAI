  "assets": {
    "images": {
      "hero_action": "https://images.unsplash.com/photo-1505250469679-203ad9ced0cb",
      "stadium_bg": "https://images.unsplash.com/photo-1707898611072-bb5cbae75929",
      "training_group": "https://images.unsplash.com/photo-1768492263433-b81fdcdce0e9",
      "video_placeholder": "https://images.unsplash.com/photo-1505250469679-203ad9ced0cb"
    },
    "icons_library": "lucide-react-native"
  },
  "features_guidelines": {
    "video_upload": {
      "instructions": "Use a clear, distraction-free overlay. When processing, show technical 'scanning' animations (e.g., lines scanning the frame) to simulate AI analysis.",
      "mock_data": {
        "score": 85,
        "speed": "105 km/h",
        "technique_feedback": "Lean forward slightly more to keep the ball low."
      }
    },
    "progress_charts": {
      "instructions": "Use 'react-native-chart-kit' or similar for dark mode charts. Lines should be Neon Green (#CCFF00) or Cyan (#00F0FF) against the dark background."
    }
  },
  "technical_rules": {
    "framework": "React Native (Expo)",
    "styling": "StyleSheet.create ONLY. No styled-components, no Tailwind classes (unless 'nativewind' is explicitly configured, but prefer StyleSheet for stability in this prompt context).",
    "navigation": "expo-router or react-navigation (Tab based).",
    "icons": "Use @expo/vector-icons or lucide-react-native.",
    "safe_area": "Always wrap main views in SafeAreaView from 'react-native-safe-area-context'.",
    "platform_specific": "Use Platform.OS === 'ios' ? ... : ... for shadow vs elevation."
  },
  "universal_guidelines": [
    "NEVER use <div>, <span>, <p>, <img>, <button>. Use <View>, <Text>, <Image>, <TouchableOpacity>.",
    "Do not use 'className'. Use 'style={styles.container}'.",
    "Text strings must always be wrapped in a <Text> component.",
    "Images must have a source object: source={{ uri: '...' }} and defined width/height.",
    "Use 'flex: 1' to fill available space.",
    "Avoid hardcoded screen dimensions. Use 'Dimensions.get('window')' or percentage widths.",
    "Ensure all touch targets (buttons, icons) are at least 44x44 points."
  ]
}